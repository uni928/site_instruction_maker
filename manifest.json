{
  "manifest_version": 3,
  "name": "Site Instruction Maker",
  "version": "1.4.0",
  "description": "サイト修正指示用のフルページスクリーンショット注釈・指示書作成ツール",
  "permissions": [
    "storage",
    "tabs",
    "downloads",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
